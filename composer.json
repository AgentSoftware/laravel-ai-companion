{
    "name": "agentsoftware/laravel-ai-token-tracker",
    "description": "Automatically track Laravel AI SDK token usage",
    "keywords": ["laravel", "ai", "tokens", "tracking"],
    "homepage": "https://github.com/agentsoftware/laravel-ai-token-tracker",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0||^13.0",
        "illuminate/support": "^12.0||^13.0",
        "laravel/ai": "^0.1||^0.4",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.15",
        "orchestra/testbench": "^10.0||^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "AgentSoftware\\LaravelAiTokenTracker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AgentSoftware\\LaravelAiTokenTracker\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AgentSoftware\\LaravelAiTokenTracker\\LaravelAiTokenTrackerServiceProvider"
            ],
            "aliases": {
                "AiUsage": "AgentSoftware\\LaravelAiTokenTracker\\Facades\\AiUsage"
            }
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "lint": "pint --parallel",
        "test:lint": "pint --parallel --test",
        "test:types": "phpstan",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:unit": "pest --parallel --coverage --exactly=100",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
